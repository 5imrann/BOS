<!-- SYSTEM GATEWAY: CONSULTATION SCHEDULING DASHBOARD HUB -->
<section class="w-full bg-[#FAF9F5] py-12 lg:py-16 px-6 sm:px-12 relative overflow-hidden min-h-screen">
  <div class="max-w-7xl mx-auto relative z-10">
    
    <!-- Dashboard Top Header Header Bar -->
    <div class="border-b border-slate-200/60 pb-6 mb-10 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <div class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400 mb-1" style="font-family: 'Inter', sans-serif;">
          Secure Gateway
        </div>
        <h1 class="text-2xl sm:text-3xl font-black tracking-tight text-slate-900" style="font-family: 'Poppins', sans-serif;">
          Corporate <span class="text-[#004B23]">Consultation</span> Dashboard
        </h1>
      </div>
      <div class="flex items-center gap-3 self-start md:self-auto bg-white border border-slate-200/80 px-4 py-2 rounded-xl shadow-sm">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-xs font-semibold text-slate-600" style="font-family: 'Inter', sans-serif;">Officer Available Direct</span>
      </div>
    </div>

    <!-- Main Dashboard Interactive Split Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- ================= LEFT HAND ROW: CONFIGURATION ENGINE (7 Columns) ================= -->
      <form action="/api/schedule-consultation" method="POST" class="lg:col-span-7 space-y-6">
        
        <!-- Step 1: Service Focus Track Selector -->
        <div class="bg-white border border-slate-200/60 p-6 rounded-2xl shadow-sm">
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-4" style="font-family: 'Inter', sans-serif;">
            1. Select Scope of Consultation
          </label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            
            <!-- Option A -->
            <label class="relative flex items-center gap-3 p-4 rounded-xl border border-slate-200/80 cursor-pointer transition-all hover:bg-slate-50/80 has-[:checked]:border-[#004B23] has-[:checked]:bg-[#004B23]/5 group">
              <input type="radio" name="consultation_scope" value="incorporation" checked class="w-4 h-4 text-[#004B23] border-slate-300 focus:ring-[#004B23]">
              <div>
                <span class="block text-sm font-bold text-slate-900">Firm Incorporation</span>
                <span class="block text-[11px] text-slate-400 mt-0.5">GST setup, Pvt Ltd, structures</span>
              </div>
            </label>

            <!-- Option B -->
            <label class="relative flex items-center gap-3 p-4 rounded-xl border border-slate-200/80 cursor-pointer transition-all hover:bg-slate-50/80 has-[:checked]:border-[#004B23] has-[:checked]:bg-[#004B23]/5 group">
              <input type="radio" name="consultation_scope" value="office_suite" class="w-4 h-4 text-[#004B23] border-slate-300 focus:ring-[#004B23]">
              <div>
                <span class="block text-sm font-bold text-slate-900">Private Managed Office</span>
                <span class="block text-[11px] text-slate-400 mt-0.5">Physical space & infrastructure</span>
              </div>
            </label>

          </div>
        </div>

        <!-- Step 2: Time Slots and Interactive Calendar Mapping Layout -->
        <div class="bg-white border border-slate-200/60 p-6 rounded-2xl shadow-sm">
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-4" style="font-family: 'Inter', sans-serif;">
            2. Strategic Timeline Schedule
          </label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-2">Preferred Target Date</label>
              <input type="date" required name="booking_date" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium focus:outline-none focus:border-[#004B23] bg-slate-50/50">
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-2">Executive Session Block</label>
              <select required name="booking_time" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium focus:outline-none focus:border-[#004B23] bg-slate-50/50">
                <option value="morning">Morning Session (10:00 AM IST)</option>
                <option value="noon">Mid-Day Session (02:30 PM IST)</option>
                <option value="evening">Late Evening Session (05:00 PM IST)</option>
              </select>
            </div>

          </div>
        </div>

        <!-- Step 3: Executive Information Mapping Fields -->
        <div class="bg-white border border-slate-200/60 p-6 rounded-2xl shadow-sm">
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-4" style="font-family: 'Inter', sans-serif;">
            3. Corporate Briefing Details
          </label>
          <div class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Authorized Contact Name</label>
                <input type="text" required placeholder="e.g. Anand Sharma" name="executive_name" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#004B23]">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Corporate Email Address</label>
                <input type="email" required placeholder="name@company.in" name="executive_email" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#004B23]">
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 mb-1.5">Primary Business Context (Optional)</label>
              <textarea placeholder="Briefly highlight any priority objectives..." name="business_notes" rows="3" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#004B23] resize-none"></textarea>
            </div>
          </div>
        </div>

        <!-- Action Button Layer with Premium Human Satin Hover Slide Effect -->
        <button type="submit" class="btn-satin-slide group w-full text-center px-8 py-4 text-xs font-bold tracking-widest uppercase text-white bg-[#004B23] rounded-xl shadow-[0_10px_25px_-10px_rgba(0,75,35,0.3)] hover:bg-[#003819] block">
          <span class="relative z-10 flex items-center justify-center gap-2">
            Confirm & Lock Consultation Slot
            <span class="transition-transform duration-300 ease-out inline-block group-hover:translate-x-1">→</span>
          </span>
        </button>

      </form>

      <!-- ================= RIGHT HAND ROW: CORPORATE MEMO SUMMARY (5 Columns) ================= -->
      <div class="lg:col-span-5 space-y-4 lg:sticky lg:top-6">
        
        <!-- Live Advisory Overview Block Layout Card -->
        <div class="relative bg-white border border-slate-200/60 p-6 rounded-2xl shadow-sm overflow-hidden">
          <div class="absolute top-0 left-0 h-full w-[4px] bg-[#FF6B35]"></div>
          
          <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400 mb-4" style="font-family: 'Inter', sans-serif;">
            Session Framework
          </p>
          
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-[#FF6B35] text-sm mt-0.5">✓</span>
              <div>
                <strong class="block text-xs text-slate-900 font-bold">Regulatory Advisory Matching</strong>
                <span class="block text-xs text-slate-500 mt-0.5">Direct onboarding guidance backed strictly by local corporate compliance statutes.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#FF6B35] text-sm mt-0.5">✓</span>
              <div>
                <strong class="block text-xs text-slate-900 font-bold">No Retainers or Hidden Billing</strong>
                <span class="block text-xs text-slate-500 mt-0.5">Your initial strategy diagnostics review is 100% complimentary.</span>
              </div>
            </li>
          </ul>

          <div class="mt-6 pt-5 border-t border-slate-100 flex items-center justify-between">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Duration Limit</span>
            <span class="text-xs font-extrabold text-[#004B23] bg-[#004B23]/5 px-2.5 py-1 rounded-md">30 Mins Strategy Call</span>
          </div>
        </div>

        <!-- System Protection Policy Summary Text Frame -->
        <div class="bg-slate-100/60 border border-slate-200/40 p-5 rounded-2xl">
          <p class="text-[11px] text-slate-400 leading-relaxed font-medium">
            Your registration data handles securely under standard state non-disclosure terms. Session details and link allocations clear safely to the email vector assigned above within 15 minutes of completion.
          </p>
        </div>

      </div>

    </div>

  </div>
</section>