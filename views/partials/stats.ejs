<section class="max-w-6xl mx-auto px-6 py-16 bg-white rounded-3xl border border-slate-200/50 my-12 shadow-sm relative overflow-hidden">
  <!-- Subtle decoration background vector flare -->
  <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-[#FF6B35]/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-y-12 gap-x-8 divide-y-0 md:divide-x divide-slate-200/80">
    
    <% if (typeof stats !== 'undefined' && stats && stats.length > 0) { %>
      <% stats.forEach((stat, index) => { %>
        <div class="text-center <%= index > 0 ? 'md:pl-6' : '' %>">
          <div class="text-4xl md:text-5xl font-black tracking-tight text-[#0F2137] font-mono bg-clip-text">
            <%= stat.value %>
          </div>
          <div class="mt-3 text-xs font-bold text-slate-400 uppercase tracking-widest leading-none">
            <%= stat.label %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <!-- Premium Defended Fallbacks -->
      <div class="text-center">
        <div class="text-4xl md:text-5xl font-black tracking-tight text-[#0F2137] font-mono">28+</div>
        <div class="mt-3 text-xs font-bold text-slate-400 uppercase tracking-widest">States Reached</div>
      </div>
      <div class="text-center md:pl-6">
        <div class="text-4xl md:text-5xl font-black tracking-tight text-[#0F2137] font-mono">10K+</div>
        <div class="mt-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Offices Connected</div>
      </div>
      <div class="text-center md:pl-6">
        <div class="text-4xl md:text-5xl font-black tracking-tight text-[#FF6B35] font-mono">99.9%</div>
        <div class="mt-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Uptime Metric</div>
      </div>
      <div class="text-center md:pl-6">
        <div class="text-4xl md:text-5xl font-black tracking-tight text-[#0F2137] font-mono">24/7</div>
        <div class="mt-3 text-xs font-bold text-slate-400 uppercase tracking-widest">Smart Support</div>
      </div>
    <% } %>

  </div>
</section>