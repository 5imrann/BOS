  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F8FAFC; }
    
    /* Saffron Underline for Setu matching the official brand site layout */
    .underline-setu {
      position: relative;
      display: inline-block;
    }
    .underline-setu::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: 2px;
      width: 100%;
      height: 4px;
      background-color: #FF6B35;
      border-radius: 2px;
