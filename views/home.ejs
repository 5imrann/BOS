       <!-- STANDALONE CONSULTATION ARRANGEMENT FORM CONTAINER -->
    
<!-- Enhanced Strategy Form -->
<div class="bg-white p-6 md:p-12 rounded-[2rem] border border-slate-200 shadow-sm">
  <h2 class="text-3xl font-black text-[#3C4E3A] mb-2">Book Strategy Briefing</h2>
  <p class="text-slate-500 mb-8">Select your parameters to align with a dedicated corporate intake officer.</p>

  <form class="space-y-8">
    
    <!-- 1. Selection Grid -->
    <div>
      <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Select Scope of Consultation</label>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="relative border-2 border-[#3C4E3A] rounded-2xl p-6 cursor-pointer bg-green-50/30">
          <input type="radio" name="scope" class="absolute top-4 right-4 accent-[#3C4E3A]" checked>
          <span class="block font-bold text-[#3C4E3A]">Firm Incorporation</span>
          <span class="block text-xs text-slate-500 mt-1">GST setup, Pvt Ltd, corporate files</span>
        </label>
        <label class="relative border-2 border-slate-200 rounded-2xl p-6 cursor-pointer hover:border-[#3C4E3A] transition-all">
          <input type="radio" name="scope" class="absolute top-4 right-4 accent-[#3C4E3A]">
          <span class="block font-bold text-[#3C4E3A]">Private Managed Office</span>
          <span class="block text-xs text-slate-500 mt-1">Physical workspace infrastructure</span>
        </label>
      </div>
    </div>

    <!-- 2. Date & Time -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Target Date</label>
        <input type="date" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 outline-none focus:border-[#3C4E3A]">
      </div>
      <div>
        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Executive Session Slot</label>
        <select class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 outline-none focus:border-[#3C4E3A]">
          <option>Morning Block (10:00 AM IST)</option>
          <option>Afternoon Block (02:00 PM IST)</option>
        </select>
      </div>
    </div>

    <!-- 3. Executive Info -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <input type="text" placeholder="Authorized Name" class="bg-slate-50 border border-slate-200 rounded-xl p-3 outline-none focus:ring-2 focus:ring-[#3C4E3A]/20">
      <input type="email" placeholder="Corporate Email" class="bg-slate-50 border border-slate-200 rounded-xl p-3 outline-none focus:ring-2 focus:ring-[#3C4E3A]/20">
    </div>

    <textarea placeholder="Briefly highlight any specific operational priorities or goals..." class="w-full bg-slate-50 border border-slate-200 rounded-xl p-4 h-24 outline-none focus:ring-2 focus:ring-[#3C4E3A]/20"></textarea>

    <button type="submit" class="w-full bg-[#3C4E3A] text-white font-bold py-4 rounded-xl hover:bg-[#FF9933] transition-all duration-300 flex items-center justify-center gap-2">
      CONFIRM & LOCK CONSULTATION SLOT →
    </button>
  </form>
</div>
