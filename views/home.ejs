        <div class="absolute top-0 left-0 h-full w-[4px] bg-[#004B23] transition-all duration-300 group-hover:w-[6px]"></div>
        <p class="text-[9px] font-bold uppercase tracking-widest text-slate-400 mb-1">Strategic Vision</p>
        <h3 class="text-sm font-bold text-slate-900 leading-snug">
          India's bridge between <span class="text-[#FF6B35]">ambition</span> and <span class="text-[#004B23]">office</span>.
        </h3>
      </div>

      <!-- Feature Block 2: GST Timeline -->
